<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Plinth</RootNamespace>
    <DefineConstants>FABLE_COMPILER</DefineConstants>
  </PropertyGroup>

  <!-- Compile order matters in F#: dependencies first. -->
  <ItemGroup>
    <Compile Include="src/Plinth/Types.fs" />
    <Compile Include="src/Plinth/Tauri.fs" />
    <Compile Include="src/Plinth/Utils/Date.fs" />
    <Compile Include="src/Plinth/Utils/Markdown.fs" />
    <Compile Include="src/Plinth/Hooks/UseNotes.fs" />
    <Compile Include="src/Plinth/Hooks/UseSearch.fs" />
    <Compile Include="src/Plinth/Hooks/UseSettings.fs" />
    <Compile Include="src/Plinth/Components/Editor.fs" />
    <Compile Include="src/Plinth/Components/Search.fs" />
    <Compile Include="src/Plinth/Components/Sidebar.fs" />
    <Compile Include="src/Plinth/Components/Backlinks.fs" />
    <Compile Include="src/Plinth/Components/Settings.fs" />
    <Compile Include="src/Plinth/Pages/NoteView.fs" />
    <Compile Include="src/Plinth/App.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Fable.Core" Version="5.*" />
    <PackageReference Include="Fable.Promise" Version="3.*" />
    <PackageReference Include="Fable.Browser.Dom" Version="2.*" />
    <PackageReference Include="Fable.Browser.WebStorage" Version="1.*" />
    <PackageReference Include="Feliz" Version="3.*" />
  </ItemGroup>

</Project>
